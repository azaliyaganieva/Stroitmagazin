<Page x:Class="Ganieva_Azaliya_006.Pages.AuthPages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ganieva_Azaliya_006.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPages">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Column="2"
            Text="Авторизация"
            FontSize="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Grid.ColumnSpan="2"/>
        <TextBlock
            Grid.Column="1"
            Grid.Row="2"
            Text="Логин:"
            FontSize="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Grid.ColumnSpan="2"/>
        <TextBox x:Name="LoginTb"
                  Grid.Column="3"
                 Grid.Row="2"
                       Width="170"
                 Height="40"
                 Grid.ColumnSpan="2"
                 FontSize="30"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"

            
            />

        <TextBlock
            Grid.Column="1"
            Grid.Row="3"
            Text="Пароль:"
            FontSize="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Grid.ColumnSpan="2"/>
        <PasswordBox x:Name="PassPb"
           Grid.Column="3"
          Grid.Row="3"
                Width="170"
          Height="40"
          Grid.ColumnSpan="2"
          FontSize="30"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"

     
     />
        <Button x:Name="AuthBtn"
                Click="AuthBtn_Click"
                Grid.Column="1"
                Grid.Row="4"
                FontSize="18"
                      Margin="10"
                Grid.ColumnSpan="2"
                Content="Войти"
                  Background="#B8860B"
            />
        <Button x:Name="GuestBtn"
        Click="GuestBtn_Click"
        Grid.Column="3"
        Grid.Row="4"
            Margin="10"
                FontSize="20"
        Grid.ColumnSpan="2"
                Content="Режим гостя"
                Background="#B8860B"
    />


    </Grid>
</Page>
